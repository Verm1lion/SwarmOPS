{
  "name": "local-kanban-planner",
  "private": true,
  "version": "0.1.0",
  "description": "Multi-user Kanban planner with Supabase backend",
  "author": "SwarmOPS",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:web": "tsc && vite build",
    "electron:dev": "cross-env ELECTRON_IS_DEV=1 electron .",
    "electron:build": "npm run build && electron-builder",
    "build:win": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:all": "npm run build && electron-builder --win --mac"
  },
  "main": "electron/main.cjs",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@hello-pangea/dnd": "^16.3.1",
    "@supabase/supabase-js": "^2.39.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  },
  "build": {
    "appId": "com.swarmops.kanban",
    "productName": "SwarmOPS Kanban Planner",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/.cache/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "electron/icons/icon.ico",
      "artifactName": "${productName}-${version}-Setup.${ext}",
      "sign": null,
      "verifyUpdateCodeSignature": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "electron/icons/icon.icns",
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}

